{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trust-layer.local/schemas/evidence-map.schema.json",
  "title": "Trust Layer Evidence Map",
  "type": "object",
  "required": ["artifact_id", "created_at", "items"],
  "properties": {
    "artifact_id": { "type": "string" },
    "created_at": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "target_id",
          "artifact_location",
          "claim_or_value",
          "source_ids",
          "source_date",
          "owner",
          "confidence",
          "review_status"
        ],
        "properties": {
          "target_id": { "type": "string" },
          "artifact_location": { "type": "string" },
          "target_type": {
            "type": "string",
            "enum": ["slide_claim", "speaker_note", "workbook_cell", "workbook_chart", "document_paragraph", "table_row", "metric"]
          },
          "claim_or_value": { "type": "string" },
          "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "source_date": { "type": "string" },
          "owner": { "type": "string" },
          "transformation": { "type": "string" },
          "assumption_flag": { "type": "boolean" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low", "contested"] },
          "review_status": { "type": "string", "enum": ["unreviewed", "reviewed", "needs_human", "blocked"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
