{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidence-map.local/schemas/review-report.schema.json",
  "title": "Evidence Map Review Report",
  "type": "object",
  "required": ["artifact_id", "created_at", "issues"],
  "properties": {
    "artifact_id": { "type": "string" },
    "created_at": { "type": "string" },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "severity", "artifact_location", "description", "requires_human"],
        "properties": {
          "issue_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "artifact_location": { "type": "string" },
          "description": { "type": "string" },
          "source_ids": { "type": "array", "items": { "type": "string" } },
          "risk_type": { "type": "string" },
          "requires_human": { "type": "boolean" },
          "recommended_owner": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
